BACKUP_OUTPUT_DIR=./backups/postgres
BACKUP_FILENAME_PREFIX=theater-db
BACKUP_KEEP_DAYS=14

# Set to 1 to encrypt the dump before upload or local storage.
BACKUP_ENCRYPT=1
BACKUP_OPENSSL_PASSPHRASE=replace_with_a_long_unique_passphrase

# Optional rclone upload target. Leave blank to keep backups local only.
# Example Google Drive target:
BACKUP_RCLONE_REMOTE=gdrive
BACKUP_RCLONE_PATH=PenncrestTheater/db-backups
BACKUP_REMOTE_KEEP_DAYS=30
