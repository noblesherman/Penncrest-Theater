{
  "name": "penncrest-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "decommissioned:notice": "node -e \"console.log('apps/api is decommissioned. Build is a no-op; use backend package for active service.');\"",
    "decommissioned": "node -e \"console.error('apps/api is decommissioned. Use npm --prefix backend run dev or npm run dev:backend for the canonical backend service.'); process.exit(1)\"",
    "dev": "npm run decommissioned",
    "build": "npm run decommissioned:notice",
    "prisma:generate": "npm run decommissioned",
    "prisma:migrate": "npm run decommissioned",
    "prisma:seed": "npm run decommissioned",
    "cron:release-holds": "npm run decommissioned"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "@prisma/client": "^6.2.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cache": "^5.1.2",
    "stripe": "^20.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.14.0",
    "@types/cors": "^2.8.17",
    "@types/node-cache": "^5.1.3",
    "prisma": "^6.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
