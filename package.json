{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite",
    "dev:backend": "npm --prefix backend run dev",
    "start:backend": "npm --prefix backend run start",
    "dev:mobile": "npm --prefix mobile run start",
    "ios": "npm --prefix mobile run ios",
    "android": "npm --prefix mobile run android",
    "dev:full": "sh -c 'npm run dev:backend & npm run dev:frontend'",
    "start": "vite",
    "seed": "tsx server/seed.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "load:flash-sale": "k6 run scripts/load/k6-prod-flash-sale.js",
    "load:flash-sale:spike": "SPIKE_MODE=true k6 run scripts/load/k6-prod-flash-sale.js",
    "backup:db": "bash ./scripts/backup-postgres.sh",
    "restore:db": "bash ./scripts/restore-postgres-backup.sh"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.11.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/canvas-confetti": "^1.9.0",
    "@types/uuid": "^10.0.0",
    "@vercel/analytics": "^2.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "canvas-confetti": "^1.9.4",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "expo": "^55.0.8",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-ical": "^0.25.4",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "0.83.2",
    "react-router-dom": "^7.13.1",
    "react-zoom-pan-pinch": "^3.7.0",
    "stripe": "^20.3.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "~19.2.10",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.1"
  }
