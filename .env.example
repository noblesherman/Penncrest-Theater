

# Frontend API base URL.
VITE_API_BASE_URL="https://api.penncresttheater.com"
VITE_STRIPE_PUBLISHABLE_KEY=""

# Local dev proxy target for /api requests.
VITE_API_PROXY_TARGET="http://localhost:4000"
# Optional when exposing the Vite dev server through a tunnel like Cloudflare.
# Accepts a comma-separated list, for example ".trycloudflare.com,my-app.ngrok-free.app"
VITE_ALLOWED_HOSTS=".trycloudflare.com"
VITE_SITE_URL="https://penncresttheater.com"
