{
  "name": "theater-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:smoke": "vitest run src/tests/critical-lifecycle.smoke.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "prisma db seed",
    "cron:release-holds": "tsx src/jobs/release-expired-holds.ts",
    "images:migrate-r2": "tsx src/scripts/migrate-images-to-r2.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.2.1",
    "@types/pdfkit": "^0.17.5",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.0.1",
    "fastify-raw-body": "^5.0.0",
    "node-ical": "^0.20.1",
    "nodemailer": "^8.0.2",
    "pdfkit": "^0.18.0",
    "stripe": "^20.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^6.4.17",
    "prisma": "^6.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.0"
  }
}
