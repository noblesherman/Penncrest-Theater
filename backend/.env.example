PORT=6000
NODE_ENV=development
# Production behind Cloudflare/reverse proxy should typically be 1
TRUST_PROXY_HOPS=0
# In production, prefer dedicated worker processes (see PM2 configs below)
ENABLE_IN_PROCESS_CHECKOUT_QUEUE_WORKER=true
ENABLE_IN_PROCESS_HOLD_CLEANUP_SCHEDULER=true
ENABLE_IN_PROCESS_HEALTH_ALERT_MONITOR=false
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/theater?schema=public"
APP_BASE_URL=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_ALLOW_DEV_TUNNEL_ORIGINS=false

STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

JWT_SECRET=replace_with_a_long_random_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_password

HOLD_TTL_MINUTES=10
HOLD_ROUTE_RATE_LIMIT_MAX=180
CHECKOUT_ATTEMPT_TTL_MINUTES=20
CHECKOUT_ROUTE_RATE_LIMIT_MAX=120
CHECKOUT_QUEUE_STATUS_ROUTE_RATE_LIMIT_MAX=3000
CHECKOUT_MAX_ACTIVE=40
CHECKOUT_QUEUE_MAX_WAIT_SECONDS=480
CHECKOUT_QUEUE_POLL_MIN_MS=1500
CHECKOUT_QUEUE_POLL_MAX_MS=4000
PERFORMANCE_CACHE_TTL_SECONDS=10
TERMINAL_DISPATCH_HOLD_TTL_MINUTES=5
TERMINAL_DISPATCH_ALLOW_MOCK_PAYMENTS=false
HOLD_CLEANUP_INTERVAL_SECONDS=60
HEALTH_ALERT_EMAIL_TO=email
HEALTH_ALERT_CHECK_INTERVAL_SECONDS=30
HEALTH_ALERT_OVERLOADED_PROBE_INTERVAL_SECONDS=90
HEALTH_ALERT_COOLDOWN_MINUTES=15
HEALTH_ALERT_CPU_PERCENT_THRESHOLD=85
HEALTH_ALERT_MEMORY_MB_THRESHOLD=1500
HEALTH_ALERT_QUEUE_WAITING_THRESHOLD=120
HEALTH_ALERT_QUEUE_LAG_SECONDS_THRESHOLD=20
HEALTH_ALERT_ERRORS_LAST_MINUTE_THRESHOLD=6
HEALTH_ALERT_DATABASE_LATENCY_MS_THRESHOLD=1200
HEALTH_ALERT_CHECKOUT_STALE_SECONDS_THRESHOLD=300
HEALTH_ALERT_CHECKOUT_STALE_QUEUE_LAG_SECONDS_THRESHOLD=45
HEALTH_ALERT_SEND_RECOVERY_EMAIL=true
HEALTH_DIAGNOSTICS_CACHE_TTL_SECONDS=10

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

STAFF_ALLOWED_DOMAIN=
STAFF_REDEEM_CODE_TTL_MINUTES=10080
TRIP_LOGIN_CODE_TTL_MINUTES=15
TRIP_LOGIN_CODE_MAX_ATTEMPTS=6
TRIP_ACCOUNT_TOKEN_TTL_HOURS=24

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:6000/auth/google/callback

MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:6000/auth/microsoft/callback
MICROSOFT_OAUTH_TENANT=common

GOOGLE_CALENDAR_ICS_URL=

# Cloudflare R2 image storage
R2_ACCOUNT_ID=
# Optional if omitted: https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public bucket/custom domain base URL (no trailing slash)
R2_PUBLIC_BASE_URL=
R2_UPLOAD_PREFIX=uploads
R2_MAX_UPLOAD_BYTES=8388608
