generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SeatStatus {
  AVAILABLE
  HELD
  SOLD
  BLOCKED
}

enum HoldStatus {
  ACTIVE
  EXPIRED
  CONVERTED
  CANCELED
}

enum OrderStatus {
  PENDING
  PAID
  FINALIZATION_FAILED
  REFUNDED
  CANCELED
}

enum CheckoutAttemptState {
  NONE
  CREATING_PAYMENT_INTENT
  AWAITING_PAYMENT
  FAILED
  EXPIRED
}

enum CheckoutQueueStatus {
  WAITING
  PROCESSING
  READY
  FAILED
  EXPIRED
  CANCELED
}

enum OrderSource {
  ONLINE
  DOOR
  COMP
  STAFF_FREE
  STAFF_COMP
  FAMILY_FREE
  STUDENT_COMP
}

enum InPersonPaymentMethod {
  STRIPE
  CASH
}

enum TerminalDispatchStatus {
  PENDING
  DELIVERED
  PROCESSING
  FAILED
  SUCCEEDED
  EXPIRED
  CANCELED
}

enum StripeWebhookEventStatus {
  PROCESSING
  PROCESSED
  FAILED
}

enum AuthProvider {
  GOOGLE
  MICROSOFT
  LOCAL
}

enum StaffVerifyMethod {
  OAUTH_GOOGLE
  OAUTH_MICROSOFT
  REDEEM_CODE
}

enum TicketType {
  PAID
  STAFF_COMP
  STUDENT_COMP
}

enum TicketStatus {
  RESERVED
  ISSUED
  CANCELLED
}

enum AdmissionDecision {
  FORCE_ADMIT
  DENY
}

enum CheckInScanAttemptAction {
  SCAN_INVALID_QR
  SCAN_NOT_FOUND
  SCAN_WRONG_PERFORMANCE
  SCAN_NOT_ADMITTED
  SCAN_ALREADY_CHECKED_IN
}

enum StudentCreditTransactionType {
  REDEEM
  ADJUSTMENT_ADD
  ADJUSTMENT_REMOVE
  MANUAL_REDEEM
  REFUND_RESTORE
}

enum StudentCreditVerificationMethod {
  CODE
  SCHOOL_LOGIN
  ADMIN
}

enum AdminRole {
  BOX_OFFICE
  ADMIN
  SUPER_ADMIN
}

enum TripPaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  EXPIRED
}

model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  name         String
  passwordHash String
  role         AdminRole @default(BOX_OFFICE)
  isActive     Boolean   @default(true)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecretEncrypted String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([role, isActive, twoFactorEnabled])
}

model User {
  id                  String                @id @default(cuid())
  email               String                @unique
  name                String
  authProvider        AuthProvider          @default(LOCAL)
  verifiedStaff       Boolean               @default(false)
  staffVerifiedAt     DateTime?
  staffVerifyMethod   StaffVerifyMethod?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  usedRedeemCodes     StaffRedeemCode[]     @relation("RedeemCodeUsedBy")
  staffCompRedemptions StaffCompRedemption[]
  orders              Order[]
  tickets             Ticket[]

  @@index([verifiedStaff, staffVerifiedAt])
}

model StaffRedeemCode {
  id              String   @id @default(cuid())
  codeHash        String   @unique
  createdByAdminId String
  expiresAt       DateTime
  usedAt          DateTime?
  usedByUserId    String?
  usedByUser      User?    @relation("RedeemCodeUsedBy", fields: [usedByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  @@index([expiresAt, usedAt])
  @@index([createdByAdminId, createdAt])
}

model TeacherCompPromoCode {
  id              String   @id @default(cuid())
  codeHash        String   @unique
  createdByAdminId String
  active          Boolean  @default(true)
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([active, expiresAt, createdAt])
  @@index([createdByAdminId, createdAt])
}

model Show {
  id          String        @id @default(cuid())
  title       String
  description String?
  posterUrl   String?
  type        String?
  year        Int?
  accentColor String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  performances Performance[]
  castMembers CastMember[]
  studentTicketCredits StudentTicketCredit[]
  programBioForm ProgramBioForm?
  seniorSendoffForm SeniorSendoffForm?
}

model CastMember {
  id        String   @id @default(cuid())
  showId    String
  show      Show     @relation(fields: [showId], references: [id], onDelete: Cascade)
  name      String
  role      String
  photoUrl  String?
  schoolEmail String?
  gradeLevel Int?
  bio       String?
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([showId, position])
  @@unique([showId, schoolEmail])
}

model ProgramBioForm {
  id              String                 @id @default(cuid())
  showId          String                 @unique
  show            Show                   @relation(fields: [showId], references: [id], onDelete: Cascade)
  publicSlug      String                 @unique
  schemaVersion   String                 @default("PROGRAM_BIO_V1")
  title           String
  instructions    String
  questionConfig  Json?
  deadlineAt      DateTime
  isOpen          Boolean                @default(true)
  createdByAdminId String?
  updatedByAdminId String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  submissions     ProgramBioSubmission[]

  @@index([isOpen, deadlineAt])
}

model ProgramBioSubmission {
  id          String         @id @default(cuid())
  formId      String
  form        ProgramBioForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  fullName    String
  schoolEmail String
  gradeLevel  Int
  roleInShow  String
  bio         String
  headshotUrl String
  headshotKey String?
  extraResponses Json?
  submittedAt DateTime       @default(now())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([formId, schoolEmail])
  @@index([formId, updatedAt])
}

model SeniorSendoffForm {
  id                       String                   @id @default(cuid())
  showId                   String                   @unique
  show                     Show                     @relation(fields: [showId], references: [id], onDelete: Cascade)
  publicSlug               String                   @unique
  schemaVersion            String                   @default("SENIOR_SENDOFF_V1")
  title                    String
  instructions             String
  questionConfig           Json?
  deadlineAt               DateTime
  isOpen                   Boolean                  @default(true)
  secondSubmissionPriceCents Int                    @default(2500)
  createdByAdminId         String?
  updatedByAdminId         String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  submissions              SeniorSendoffSubmission[]

  @@index([isOpen, deadlineAt])
}

model SeniorSendoffSubmission {
  id                String            @id @default(cuid())
  formId            String
  form              SeniorSendoffForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  parentName        String
  parentEmail       String
  parentPhone       String
  studentName       String
  studentKey        String
  message           String
  extraResponses    Json?
  entryNumber       Int
  isPaid            Boolean           @default(false)
  paymentIntentId   String?           @unique
  paymentAmountCents Int?
  paymentCurrency   String?
  submittedAt       DateTime          @default(now())
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([formId, parentEmail, studentKey, entryNumber])
  @@index([formId, updatedAt])
  @@index([formId, parentEmail, studentKey])
}

model Performance {
  id           String        @id @default(cuid())
  showId        String
  show          Show          @relation(fields: [showId], references: [id], onDelete: Cascade)
  title         String?
  startsAt      DateTime
  onlineSalesStartsAt DateTime?
  salesCutoffAt DateTime?
  isPublished   Boolean       @default(true)
  isArchived    Boolean       @default(false)
  isFundraiser  Boolean       @default(false)
  archivedAt    DateTime?
  staffTicketLimit Int       @default(2)
  staffCompsEnabled Boolean  @default(true)
  staffCompLimitPerUser Int  @default(1)
  familyFreeTicketEnabled Boolean @default(false)
  seatSelectionEnabled Boolean @default(true)
  venue         String
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  seats         Seat[]
  pricingTiers  PricingTier[]
  holdSessions  HoldSession[]
  orders        Order[]
  tickets       Ticket[]
  scannerSessions ScannerSession[]
  checkInScanAttempts CheckInScanAttempt[]
  staffCompRedemptions StaffCompRedemption[]
  studentTicketCreditTransactions StudentTicketCreditTransaction[]
  terminalPaymentDispatches TerminalPaymentDispatch[]
  checkoutQueueItems CheckoutQueueItem[]

  @@index([showId])
  @@index([startsAt])
  @@index([isPublished, onlineSalesStartsAt])
  @@index([isArchived, startsAt])
}

model PricingTier {
  id            String      @id @default(cuid())
  performanceId String
  performance   Performance @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  name          String
  priceCents    Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([performanceId])
}

model Seat {
  id            String       @id @default(cuid())
  performanceId String
  performance   Performance  @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  row           String
  number        Int
  sectionName   String
  x             Int
  y             Int
  price         Int
  isAccessible  Boolean      @default(false)
  isCompanion   Boolean      @default(false)
  companionForSeatId String?
  companionForSeat Seat?     @relation("CompanionSeat", fields: [companionForSeatId], references: [id], onDelete: SetNull)
  companionSeats Seat[]      @relation("CompanionSeat")
  status        SeatStatus   @default(AVAILABLE)
  holdSessionId String?
  holdSession   HoldSession? @relation(fields: [holdSessionId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  seatHolds     SeatHold[]
  orderSeats    OrderSeat[]
  tickets       Ticket[]

  @@unique([performanceId, sectionName, row, number])
  @@index([performanceId, status])
  @@index([holdSessionId])
  @@index([companionForSeatId])
}

model HoldSession {
  id            String      @id @default(cuid())
  performanceId String
  performance   Performance @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  clientToken   String
  holdToken     String      @unique
  expiresAt     DateTime
  status        HoldStatus  @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  seats         Seat[]
  seatHolds     SeatHold[]

  @@unique([performanceId, clientToken])
  @@index([performanceId, expiresAt])
}

model SeatHold {
  id            String      @id @default(cuid())
  seatId        String
  seat          Seat        @relation(fields: [seatId], references: [id], onDelete: Cascade)
  holdSessionId String
  holdSession   HoldSession @relation(fields: [holdSessionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([seatId])
  @@unique([holdSessionId, seatId])
  @@index([holdSessionId])
}

model Order {
  id                    String      @id @default(cuid())
  performanceId         String
  performance           Performance @relation(fields: [performanceId], references: [id], onDelete: Restrict)
  userId                String?
  user                  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  stripeSessionId       String?     @unique
  stripePaymentIntentId String?     @unique
  email                 String
  customerName          String
  customerPhone         String?
  attendeeNamesJson     Json?
  amountTotal           Int
  currency              String      @default("usd")
  status                OrderStatus @default(PENDING)
  checkoutAttemptState  CheckoutAttemptState @default(NONE)
  checkoutAttemptExpiresAt DateTime?
  source                OrderSource @default(ONLINE)
  inPersonPaymentMethod InPersonPaymentMethod?
  holdToken             String?
  studentTicketCreditId String?
  studentTicketCredit   StudentTicketCredit? @relation(fields: [studentTicketCreditId], references: [id], onDelete: SetNull)
  studentCreditPendingQuantity Int @default(0)
  studentCreditRedeemedQuantity Int @default(0)
  studentCreditRestoredQuantity Int @default(0)
  studentCreditVerificationMethod StudentCreditVerificationMethod?
  accessToken           String      @unique
  finalizationAttemptCount Int      @default(0)
  finalizationFailedAt  DateTime?
  lastFinalizationError String?
  stripeRefundId        String?     @unique
  stripeRefundStatus    String?
  refundAmountCents     Int         @default(0)
  refundRequestedAt     DateTime?
  refundedAt            DateTime?
  lastRefundError       String?
  releaseSeatsOnRefund  Boolean     @default(false)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  orderSeats            OrderSeat[]
  tickets               Ticket[]
  studentTicketCreditTransactions StudentTicketCreditTransaction[]
  terminalDispatchFinalizations TerminalPaymentDispatch[] @relation("TerminalDispatchFinalOrder")
  checkoutQueueItems CheckoutQueueItem[]

  @@index([performanceId])
  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([status, checkoutAttemptState, checkoutAttemptExpiresAt])
  @@index([source, inPersonPaymentMethod, createdAt])
  @@index([studentTicketCreditId])
  @@index([accessToken])
}

model CheckoutQueueItem {
  id                  String              @id @default(cuid())
  performanceId       String
  performance         Performance         @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  holdToken           String
  clientToken         String
  requestPayloadJson  Json
  status              CheckoutQueueStatus @default(WAITING)
  expiresAt           DateTime
  processingStartedAt DateTime?
  readyAt             DateTime?
  failedReason        String?
  orderId             String?
  order               Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  paymentIntentId     String?
  clientSecret        String?
  attemptCount        Int                 @default(0)
  nextAttemptAt       DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([holdToken, clientToken])
  @@index([status, createdAt])
  @@index([performanceId, status, createdAt])
  @@index([expiresAt])
}

model TerminalDeviceSession {
  id                String   @id @default(cuid())
  deviceId          String   @unique
  displayName       String
  isOnline          Boolean  @default(true)
  registeredByAdminId String?
  lastHeartbeatAt   DateTime @default(now())
  lastDispatchPollAt DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  dispatches        TerminalPaymentDispatch[] @relation("TerminalDeviceDispatches")

  @@index([isOnline, lastHeartbeatAt])
  @@index([displayName])
}

model TerminalPaymentDispatch {
  id                              String                @id @default(cuid())
  status                          TerminalDispatchStatus @default(PENDING)
  performanceId                   String
  performance                     Performance           @relation(fields: [performanceId], references: [id], onDelete: Restrict)
  targetDeviceSessionId           String
  targetDeviceSession             TerminalDeviceSession @relation("TerminalDeviceDispatches", fields: [targetDeviceSessionId], references: [id], onDelete: Restrict)
  targetDeviceId                  String
  holdToken                       String
  holdExpiresAt                   DateTime
  expectedAmountCents             Int
  currency                        String                @default("usd")
  stripePaymentIntentId           String?               @unique
  stripePaymentIntentClientSecret String?
  saleSnapshot                    Json
  attemptCount                    Int                   @default(1)
  failureReason                   String?
  deliveredAt                     DateTime?
  processingStartedAt             DateTime?
  completedAt                     DateTime?
  canceledAt                      DateTime?
  finalOrderId                    String?               @unique
  finalOrder                      Order?                @relation("TerminalDispatchFinalOrder", fields: [finalOrderId], references: [id], onDelete: SetNull)
  createdByAdminId                String?
  createdAt                       DateTime              @default(now())
  updatedAt                       DateTime              @updatedAt

  @@index([targetDeviceId, status, createdAt])
  @@index([status, holdExpiresAt])
  @@index([performanceId, createdAt])
}

model OrderSeat {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  seatId       String?
  seat         Seat?    @relation(fields: [seatId], references: [id], onDelete: SetNull)
  ticketType   String?
  isComplimentary Boolean @default(false)
  price        Int
  attendeeName String?
  createdAt    DateTime @default(now())

  @@unique([orderId, seatId])
  @@index([seatId])
  @@index([orderId])
}

model Ticket {
  id          String               @id
  orderId     String
  order       Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  performanceId String
  performance Performance          @relation(fields: [performanceId], references: [id], onDelete: Restrict)
  userId      String?
  user        User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  seatId      String?
  seat        Seat?                @relation(fields: [seatId], references: [id], onDelete: SetNull)
  type        TicketType           @default(PAID)
  priceCents  Int                  @default(0)
  status      TicketStatus         @default(ISSUED)
  publicId    String               @unique
  qrSecret    String
  qrPayload   String
  checkedInAt DateTime?
  checkedInBy String?
  checkInGate String?
  admissionDecision AdmissionDecision?
  admissionReason String?
  admissionDecidedAt DateTime?
  admissionDecidedBy String?
  createdAt   DateTime             @default(now())
  scanAttempts CheckInScanAttempt[]
  staffCompRedemption StaffCompRedemption?

  @@index([orderId])
  @@index([performanceId])
  @@index([userId])
  @@index([type, status])
  @@index([seatId])
  @@index([performanceId, checkedInAt])
  @@index([performanceId, admissionDecision])
}

model ScannerSession {
  id            String      @id @default(cuid())
  performanceId String
  performance   Performance @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  accessToken   String      @unique
  staffName     String
  gate          String
  deviceLabel   String?
  active        Boolean     @default(true)
  createdBy     String?
  lastSeenAt    DateTime    @default(now())
  endedAt       DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  scanAttempts  CheckInScanAttempt[]

  @@index([performanceId, active])
  @@index([performanceId, gate, active])
  @@index([lastSeenAt])
}

model CheckInScanAttempt {
  id               String                   @id @default(cuid())
  performanceId    String
  performance      Performance              @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  scannerSessionId String?
  scannerSession   ScannerSession?          @relation(fields: [scannerSessionId], references: [id], onDelete: SetNull)
  ticketId         String?
  ticket           Ticket?                  @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  publicId         String?
  action           CheckInScanAttemptAction
  actor            String
  gate             String?
  scannedValue     String?
  clientScanId     String?
  offlineQueuedAt  DateTime?
  details          Json?
  createdAt        DateTime                 @default(now())

  @@index([performanceId, createdAt])
  @@index([performanceId, action, createdAt])
  @@index([scannerSessionId, createdAt])
  @@index([ticketId, createdAt])
}

model StaffCompRedemption {
  id            String      @id @default(cuid())
  performanceId String
  performance   Performance @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketId      String      @unique
  ticket        Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  redeemedAt    DateTime    @default(now())

  @@unique([performanceId, userId])
  @@index([performanceId, redeemedAt])
  @@index([userId, redeemedAt])
}

model StudentTicketCredit {
  id               String   @id @default(cuid())
  showId           String
  show             Show     @relation(fields: [showId], references: [id], onDelete: Cascade)
  studentId        String?
  studentName      String
  studentEmail     String?
  roleName         String?
  verificationCode String?  @unique
  allocatedTickets Int      @default(2)
  usedTickets      Int      @default(0)
  pendingTickets   Int      @default(0)
  isActive         Boolean  @default(true)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  transactions     StudentTicketCreditTransaction[]
  orders           Order[]

  @@index([showId, isActive])
}

model StudentTicketCreditTransaction {
  id                    String                          @id @default(cuid())
  studentTicketCreditId String
  studentTicketCredit   StudentTicketCredit            @relation(fields: [studentTicketCreditId], references: [id], onDelete: Cascade)
  orderId               String?
  order                 Order?                         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  performanceId         String?
  performance           Performance?                   @relation(fields: [performanceId], references: [id], onDelete: SetNull)
  quantity              Int
  type                  StudentCreditTransactionType
  verificationMethod    StudentCreditVerificationMethod?
  redeemedBy            String?
  notes                 String?
  createdAt             DateTime                       @default(now())

  @@index([studentTicketCreditId, createdAt])
  @@index([orderId])
  @@index([performanceId])
}

model StripeWebhookEvent {
  id          String                   @id @default(cuid())
  eventId     String                   @unique
  eventType   String
  status      StripeWebhookEventStatus @default(PROCESSING)
  processedAt DateTime?
  lastError   String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([status, createdAt])
  @@index([eventType, createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  actor        String
  actorUserId  String?
  actorAdminId String?
  action       String
  entityType   String
  entityId     String
  meta         Json?
  metadataJson Json?
  createdAt    DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([actorAdminId, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model DriveFolder {
  id               String       @id @default(cuid())
  name             String
  parentId         String?
  parent           DriveFolder? @relation("DriveFolderTree", fields: [parentId], references: [id], onDelete: Restrict)
  children         DriveFolder[] @relation("DriveFolderTree")
  files            DriveFile[]
  createdByAdminId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([parentId, name])
  @@index([parentId, name])
  @@index([createdByAdminId, createdAt])
}

model DriveFile {
  id                String      @id @default(cuid())
  folderId          String?
  folder            DriveFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  displayName       String
  objectKey         String      @unique
  publicUrl         String
  mimeType          String
  sizeBytes         Int
  uploadedByAdminId String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([folderId, createdAt])
  @@index([uploadedByAdminId, createdAt])
}

model ContentPage {
  id              String   @id @default(cuid())
  scope           String
  slug            String
  title           String
  content         Json
  draftContent    Json?
  publishedContent Json?
  catalogDraft    Json?
  catalogPublished Json?
  draftDeleted    Boolean  @default(false)
  publishedDeleted Boolean @default(false)
  updatedByAdminId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([scope, slug])
  @@index([scope])
  @@index([updatedByAdminId])
}

model Trip {
  id                  String           @id @default(cuid())
  title               String
  slug                String           @unique
  destination         String?
  startsAt            DateTime?
  dueAt               DateTime
  defaultCostCents    Int
  allowPartialPayments Boolean         @default(false)
  isPublished         Boolean          @default(false)
  isArchived          Boolean          @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  documents           TripDocument[]
  enrollments         TripEnrollment[]

  @@index([isPublished, isArchived, dueAt])
  @@index([startsAt])
}

model TripDocument {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  title     String
  fileUrl   String
  fileKey   String?
  mimeType  String
  sizeBytes Int
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId, sortOrder, createdAt])
}

model TripStudent {
  id         String           @id @default(cuid())
  name       String
  grade      String?
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  enrollments TripEnrollment[]
  account    TripAccount?

  @@index([isActive, name])
}

model TripEnrollment {
  id               String                  @id @default(cuid())
  tripId           String
  trip             Trip                    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  studentId        String
  student          TripStudent             @relation(fields: [studentId], references: [id], onDelete: Restrict)
  targetAmountCents Int
  dueAtOverride    DateTime?
  claimedByAccountId String?
  claimedByAccount TripAccount?            @relation("TripEnrollmentClaimedBy", fields: [claimedByAccountId], references: [id], onDelete: SetNull)
  claimedAt        DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  payments         TripPayment[]
  balanceAdjustments TripBalanceAdjustment[]

  @@unique([tripId, studentId])
  @@index([studentId, tripId])
  @@index([claimedByAccountId])
  @@index([dueAtOverride])
}

model TripAccount {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  studentId        String?           @unique
  student          TripStudent?      @relation(fields: [studentId], references: [id], onDelete: SetNull)
  stripeCustomerId String?
  isActive         Boolean           @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  loginCodes       TripLoginCode[]
  payments         TripPayment[]
  claimedEnrollments TripEnrollment[] @relation("TripEnrollmentClaimedBy")

  @@index([isActive, lastLoginAt])
}

model TripLoginCode {
  id          String      @id @default(cuid())
  accountId   String
  account     TripAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?
  attemptCount Int        @default(0)
  createdAt   DateTime    @default(now())

  @@index([accountId, createdAt])
  @@index([accountId, expiresAt, consumedAt])
}

model TripPayment {
  id                      String            @id @default(cuid())
  enrollmentId            String
  enrollment              TripEnrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  accountId               String
  account                 TripAccount       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  amountCents             Int
  currency                String            @default("usd")
  stripeCheckoutSessionId String?           @unique
  stripePaymentIntentId   String?           @unique
  status                  TripPaymentStatus @default(PENDING)
  paidAt                  DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  @@index([enrollmentId, status, createdAt])
  @@index([accountId, createdAt])
}

model TripBalanceAdjustment {
  id                      String         @id @default(cuid())
  enrollmentId            String
  enrollment              TripEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  previousTargetAmountCents Int
  newTargetAmountCents    Int
  reason                  String
  actorAdminId            String?
  createdAt               DateTime       @default(now())

  @@index([enrollmentId, createdAt])
  @@index([actorAdminId, createdAt])
}
